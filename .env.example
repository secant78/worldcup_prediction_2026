# Reddit API (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=worldcup-sentiment-tracker/1.0

# X/Twitter API (optional, requires paid access)
TWITTER_BEARER_TOKEN=your_bearer_token

# Football-Data.org API (https://www.football-data.org/client/register)
FOOTBALL_DATA_API_KEY=your_api_key

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Elasticsearch
ES_HOST=http://localhost:9200
ES_INDEX=worldcup-sentiment
ES_MATCHES_INDEX=worldcup-matches
